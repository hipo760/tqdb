# Copy this file to .env and fill in your values.
# The docker-compose.yml reads from .env automatically.

# Cassandra
CASSANDRA_HOST=cassandra
CASSANDRA_PORT=9042
CASSANDRA_USER=tqdb
CASSANDRA_PASSWORD=tqdb1234
CASSANDRA_KEYSPACE=tqdb1
CASSANDRA_TABLE=minbar

# Symbol source: "api" or "file"
SYMBOL_SOURCE=api
SYMBOL_API_URL=https://example.com/intra/crypto/gta_symbol
SYMBOL_API_TOKEN=your-bearer-token-here

# Daily job: how many days to patch at UTC 00:00
DAILY_BACKFILL_DAYS=3

# Host port the API is bound to
BACKFILL_API_PORT=8765

# Only used when SYMBOL_SOURCE=file — absolute path on the host
# SYMBOLS_FILE=/path/to/symbols.json
